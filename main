#!/bin/bash
#PBS -l nodes=1:ppn=4
#PBS -l mem=32gb
#PBS -l walltime=24:00:00
set -e

# Make output directory
mkdir -p out_dir
mkdir -p html_report

# Limit threads to avoid OOM; n_jobs=2 in pipeline_config for recon-all/source
export OMP_NUM_THREADS=2
export OPENBLAS_NUM_THREADS=2
export MKL_NUM_THREADS=2
export NUMEXPR_NUM_THREADS=2
export VECLIB_MAXIMUM_THREADS=2
export SINGULARITYENV_OMP_NUM_THREADS=2
export SINGULARITYENV_OPENBLAS_NUM_THREADS=2
export SINGULARITYENV_MKL_NUM_THREADS=2
export SINGULARITYENV_NUMEXPR_NUM_THREADS=2
export SINGULARITYENV_VECLIB_MAXIMUM_THREADS=2

# Headless rendering (PyVista / MNE 3D)
export SINGULARITYENV_PYVISTA_OFF_SCREEN="true"
export SINGULARITYENV_QT_QPA_PLATFORM="offscreen"
export SINGULARITYENV_MPLBACKEND="Agg"
export SINGULARITYENV_MNE_3D_BACKEND="pyvistaqt"
export SINGULARITYENV_VTK_DEFAULT_OPENGL_WINDOW="vtkOSOpenGLRenderWindow"

# FreeSurfer: use Docker install paths; license comes from the compute resource
export SINGULARITYENV_FREESURFER_HOME="/opt/freesurfer"
export SINGULARITYENV_PERL5LIB="/opt/freesurfer/mni/lib/perl5"
export SINGULARITYENV_FS_LICENSE="$FS_LICENSE"

